<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="Sevimli TZD"
        android:supportsRtl="true"
        android:theme="@style/Theme.SevimliTZD">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.SevimliTZD.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MenuActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".LookupActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SupplyActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".CounterpartyActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ProductSearchActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
    </application>
</manifest>
