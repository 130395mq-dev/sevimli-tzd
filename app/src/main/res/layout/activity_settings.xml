<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- SARLAVHA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_header"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:paddingEnd="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sozlamalar"
            android:textColor="@color/white"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- LOGIN BOSQICHI -->
    <LinearLayout
        android:id="@+id/loginStage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="6dp"
            android:text="Menejer kirishi"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:text="Sozlamani faqat menejer o'zgartiradi"
            android:textColor="@color/text_gray"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/inLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="Login"
            android:inputType="text"
            android:background="@drawable/bg_chip"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/inPassword"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="Parol"
            android:inputType="textPassword"
            android:background="@drawable/bg_chip"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Kirish"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/brand"
            app:cornerRadius="14dp" />

        <TextView
            android:id="@+id/loginError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:textColor="@color/brand"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- SOZLAMALAR (login'dan keyin) — bitta scroll -->
    <ScrollView
        android:id="@+id/storeStage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- BO'LIMLAR (dashboard) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="2dp"
                android:text="Bo'limlar (dashboardда ko'rinishi)"
                android:textColor="@color/text_dark"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                android:text="Kerakli bo'limlarni yoqing — menyuda faqat o'shalar chiqadi. «Просмотр товара» doim ko'rinadi."
                android:textColor="@color/text_gray"
                android:textSize="13sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:id="@+id/fnList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/card_stroke"
                android:layout_marginBottom="16dp" />

            <!-- QURILMA TOKENI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"
                android:text="Qurilma tokeni"
                android:textColor="@color/text_dark"
                android:textSize="17sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inToken"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="Qurilma tokeni (admin paneldan)"
                android:inputType="text"
                android:maxLines="1"
                android:background="@drawable/bg_chip"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveToken"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Tokenni saqlash"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:backgroundTint="@color/brand"
                app:cornerRadius="14dp"
                android:layout_marginBottom="18dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/card_stroke"
                android:layout_marginBottom="16dp" />

            <!-- ORGANIZATSIYA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"
                android:text="Organizatsiya (yuridik shaxs)"
                android:textColor="@color/text_dark"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOrg"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Organizatsiyani tanlash"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:backgroundTint="@color/pill_gray"
                android:textColor="@color/text_dark"
                app:cornerRadius="14dp"
                android:layout_marginBottom="18dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/card_stroke"
                android:layout_marginBottom="16dp" />

            <!-- NARX TURI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="2dp"
                android:text="Narx turi (ценник)"
                android:textColor="@color/text_dark"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                android:text="Optom (ulgurji) filialда yoqing — ценник ulgurji narxда chiqadi. Boshqasida o'chiq (chakana)."
                android:textColor="@color/text_gray"
                android:textSize="13sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ulgurji narx (оптом)"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="optom savdo filiali uchun"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/swUlgurji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/card_stroke"
                android:layout_marginBottom="16dp" />

            <!-- SKLAD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="2dp"
                android:text="Qurilma qaysi skladga ishlaydi?"
                android:textColor="@color/text_dark"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                android:text="Tanlangan sklad barcha funksiyaga amal qiladi"
                android:textColor="@color/text_gray"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/storeList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/loading"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_gravity="center"
        android:layout_margin="20dp"
        android:indeterminateTint="@color/brand"
        android:visibility="gone" />
</LinearLayout>
