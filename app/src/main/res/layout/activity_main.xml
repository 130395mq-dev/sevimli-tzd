<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SEVIMLI TZD — Skaner testi"
        android:textStyle="bold"
        android:textSize="18sp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/methodText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Usul: —"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/lastScan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Skan kutilmoqda..."
        android:textSize="28sp"
        android:textStyle="bold"
        android:paddingTop="12dp"
        android:paddingBottom="12dp" />

    <EditText
        android:id="@+id/wedgeInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Bu yerga skan / qo'lda kiriting"
        android:inputType="text"
        android:imeOptions="actionDone" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tarix (yangi tepada):"
        android:textStyle="bold"
        android:paddingTop="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingTop="6dp" />
    </ScrollView>
</LinearLayout>
