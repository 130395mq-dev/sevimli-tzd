<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="24dp">

        <ImageView
            android:layout_width="150dp"
            android:layout_height="60dp"
            android:src="@drawable/logo_wide"
            android:scaleType="fitStart"
            android:contentDescription="TSD" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ombor boshqaruv tizimi"
            android:textColor="@color/white70"
            android:textSize="13sp"
            android:letterSpacing="0.04" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_icon_circle_dark"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="#7CFC9A" />

                <TextView
                    android:id="@+id/statusChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="Sklad tanlanmagan"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/btnRefresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_icon_circle_dark"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_refresh"
                    android:tint="@color/white"
                    android:contentDescription="Yangilash" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Yangilash"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="10dp"
                android:text="Bo'limlar"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLookup"
                    style="@style/MenuCard"
                    android:layout_marginEnd="10dp"
                    app:cardBackgroundColor="@color/brand">

                    <LinearLayout style="@style/MenuCardInner">
                        <FrameLayout style="@style/MenuIconWrap" android:background="@drawable/bg_icon_circle_dark">
                            <ImageView style="@style/MenuIcon" android:src="@drawable/ic_lookup" app:tint="@color/white"/>
                        </FrameLayout>
                        <TextView style="@style/MenuCardTitle" android:text="Просмотр товара" android:textColor="@color/white"/>
                        <TextView style="@style/MenuCardSub" android:text="Narx va qoldiq" android:textColor="@color/white70"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardReceiving"
                    style="@style/MenuCard">

                    <LinearLayout style="@style/MenuCardInner">
                        <FrameLayout style="@style/MenuIconWrap" android:background="@drawable/bg_icon_circle">
                            <ImageView style="@style/MenuIcon" android:src="@drawable/ic_receive" app:tint="@color/brand"/>
                        </FrameLayout>
                        <TextView style="@style/MenuCardTitle" android:text="Приёмка"/>
                        <TextView style="@style/MenuCardSub" android:text="qabul"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardInventory"
                    style="@style/MenuCard"
                    android:layout_marginEnd="10dp">

                    <LinearLayout style="@style/MenuCardInner">
                        <FrameLayout style="@style/MenuIconWrap" android:background="@drawable/bg_icon_circle">
                            <ImageView style="@style/MenuIcon" android:src="@drawable/ic_inventory" app:tint="@color/brand"/>
                        </FrameLayout>
                        <TextView style="@style/MenuCardTitle" android:text="Инвентаризация"/>
                        <TextView style="@style/MenuCardSub" android:text="sanoq"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMove"
                    style="@style/MenuCard">

                    <LinearLayout style="@style/MenuCardInner">
                        <FrameLayout style="@style/MenuIconWrap" android:background="@drawable/bg_icon_circle">
                            <ImageView style="@style/MenuIcon" android:src="@drawable/ic_move" app:tint="@color/brand"/>
                        </FrameLayout>
                        <TextView style="@style/MenuCardTitle" android:text="Перемещение"/>
                        <TextView style="@style/MenuCardSub" android:text="ko'chirish"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPicking"
                    style="@style/MenuCard"
                    android:layout_marginEnd="10dp">

                    <LinearLayout style="@style/MenuCardInner">
                        <FrameLayout style="@style/MenuIconWrap" android:background="@drawable/bg_icon_circle">
                            <ImageView style="@style/MenuIcon" android:src="@drawable/ic_pick" app:tint="@color/brand"/>
                        </FrameLayout>
                        <TextView style="@style/MenuCardTitle" android:text="Отгрузка"/>
                        <TextView style="@style/MenuCardSub" android:text="mijozga jo'natish"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWriteoff"
                    style="@style/MenuCard">

                    <LinearLayout style="@style/MenuCardInner">
                        <FrameLayout style="@style/MenuIconWrap" android:background="@drawable/bg_icon_circle">
                            <ImageView style="@style/MenuIcon" android:src="@drawable/ic_writeoff" app:tint="@color/brand"/>
                        </FrameLayout>
                        <TextView style="@style/MenuCardTitle" android:text="Списание"/>
                        <TextView style="@style/MenuCardSub" android:text="qabul"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardScannerTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout style="@style/MenuIconWrap" android:background="@drawable/bg_icon_circle">
                        <ImageView style="@style/MenuIcon" android:src="@drawable/ic_settings" app:tint="@color/brand"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <TextView style="@style/MenuCardTitle" android:layout_marginTop="0dp" android:text="Sozlamalar"/>
                        <TextView style="@style/MenuCardSub" android:text="Menejer · sklad tanlash"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/footerVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dp"
        android:text="v0.5 · Sevimli Market"
        android:textColor="@color/text_gray"
        android:textSize="12sp" />
</LinearLayout>
